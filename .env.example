# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://scraper:scraper_pass@localhost:5432/scraper_db

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_BROKER_URL=redis://localhost:6379/1

# ─── Security ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ENCRYPTION_KEY=change-me-to-32-bytes-base64-key==

JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ─── Ollama (AI Pipeline) ───────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:8b

# ─── Proxy Pool (optional) ──────────────────────────────────
PROXY_POOL_URL=
PROXY_POOL_USERNAME=
PROXY_POOL_PASSWORD=

# ─── Notifications (optional) ───────────────────────────────
SLACK_WEBHOOK_URL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# ─── External APIs (optional) ───────────────────────────────
DATA_GO_KR_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_REST_API_KEY=
DART_API_KEY=
YOUTUBE_API_KEY=

# ─── App Settings ───────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# ─── Rate Limiting ──────────────────────────────────────────
DEFAULT_RATE_LIMIT_DELAY_MS=1000
MAX_CONCURRENT_PER_DOMAIN=5
